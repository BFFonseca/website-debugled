---
const navLinks = [
  { href: '/',         label: '~/home'     },
  { href: '/projects', label: '~/projects' },
  { href: '/blog',     label: '~/blog'     },
  { href: '/contact',  label: '~/contact'  },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-gray-800 px-6 py-4">
  <nav class="max-w-4xl mx-auto flex items-center justify-between">
    <a href="/" class="font-mono font-medium text-led-green text-lg tracking-tight">
      debug<span class="text-led-light">LED</span>
    </a>
    <ul class="flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`nav-link ${currentPath === link.href ? 'text-led-green' : ''}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
