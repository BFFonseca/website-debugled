---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Who am I?">
    <section class="mb-20">
        <h1 class="section-title text-4xl mb-2">About</h1>
        <p class="led-accent text-sm mb-12">// a bit more about who I am</p>

        <div class="max-w-xl">
            <div class="card mb-8">
            <p class="t-muted leading-relaxed mb-6">
                My name is Bruno Fonseca and I'm an guy with a passion for technology.<br>
                I'm most experienced in Firmware and Embedded Software development.<br>
                I have a background in Electrical Engineering and I love to build things and watch them come to life.<br>
                I also like to experiment with 3D printing, 3D design, hardware and home automation.<br>
                In my free time I like to cook, play video games, practice martial arts and be in nature.<br>
            </p>
            </div>
        </div>
    </section>
</BaseLayout>
