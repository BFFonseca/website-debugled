---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with me.">
  <section class="mb-20">
    <h1 class="section-title text-4xl mb-2">Contact</h1>
    <p class="led-accent text-sm mb-12">// get in touch</p>

    <div class="max-w-xl">
      <div class="card mb-8">
        <p class="t-muted leading-relaxed mb-6">
          Have a question, a project idea, or just want to say hi?
          The best way to reach me is by email or linkedin.
        </p>

        <div class="flex flex-col gap-4 font-mono text-sm">
          <div class="flex items-center gap-3">
            <span class="t-accent w-20">email</span>
            <a href="mailto:debugled@proton.me" class="t-muted hover-accent transition-colors">
              debugled@proton.me
            </a>
          </div>
          <div class="flex items-center gap-3">
            <span class="t-accent w-20">github</span>
            <a href="https://github.com/bffonseca" target="_blank" rel="noopener" class="t-muted hover-accent transition-colors">
              github.com/bffonseca
            </a>
          </div>
          <div class="flex items-center gap-3">
            <span class="t-accent w-20">linkedin</span>
            <a href="https://www.linkedin.com/in/brunoriofonseca/" target="_blank" rel="noopener" class="t-muted hover-accent transition-colors">
              https://www.linkedin.com/in/brunoriofonseca/
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
