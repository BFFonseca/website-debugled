---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = await getCollection('projects');
---

<BaseLayout title="Projects" description="Things I've built.">
  <section class="mb-20">
    <h1 class="section-title text-4xl mb-2">Projects</h1>
    <p class="led-accent text-sm mb-12">// things I've shipped</p>

    <div class="grid gap-6">
      {projects.map(project => (
        <div class="card group">
          <div class="flex items-start justify-between gap-4 mb-3">
            <a href={`/projects/${project.id.split('/').pop()?.replace(/\.md$/, '')}`}>
              <h2 class="font-display text-xl font-semibold t-text group-hover-accent transition-colors">
                {project.data.title}
              </h2>
            </a>
            <span class={`font-mono text-xs px-2 py-1 rounded-full border ${
              project.data.status === 'active' ? 't-accent b-accent' : 't-muted b-border'
            }`}>
              {project.data.status}
            </span>
          </div>

          <p class="t-muted text-sm leading-relaxed mb-5">
            {project.data.description}
          </p>

          <div class="flex items-center justify-between">
            <div class="flex flex-wrap gap-2">
              {project.data.tags.map(tag => (
                <span class="whitespace-nowrap font-mono text-xs t-muted b-border border px-2 py-1 rounded">
                  {tag}
                </span>
              ))}
            </div>
            <div class="flex gap-3 text-sm font-mono">
              {project.data.repo && (
                <a href={project.data.repo} target="_blank" rel="noopener" class="t-muted hover-accent transition-colors">
                  repo ↗
                </a>
              )}
              {project.data.live && (
                <a href={project.data.live} target="_blank" rel="noopener" class="t-muted hover-accent transition-colors">
                  live ↗
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
