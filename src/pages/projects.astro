---
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: replace with your real projects
const projects = [
  {
    title: 'Project Alpha',
    description: 'A short description of what this project does and why it matters.',
    tags: ['TypeScript', 'Astro'],
    repo: 'https://github.com/',
    live: '',
    status: 'active',
  },
  {
    title: 'Project Beta',
    description: 'Another project. What problem did you solve? What did you learn?',
    tags: ['Python', 'CLI'],
    repo: 'https://github.com/',
    live: '',
    status: 'complete',
  },
];
---

<BaseLayout title="Projects" description="Things I've built.">
  <h1 class="section-title text-4xl mb-2">Projects</h1>
  <p class="led-accent text-sm mb-12">// things I've shipped</p>

  <div class="grid gap-6">
    {projects.map(project => (
      <div class="card group">
        <div class="flex items-start justify-between gap-4 mb-3">
          <h2 class="font-display text-xl font-semibold text-led-light group-hover:text-led-green transition-colors">
            {project.title}
          </h2>
          <span class={`font-mono text-xs px-2 py-1 rounded-full border ${
            project.status === 'active'
              ? 'border-led-green text-led-green'
              : 'border-gray-700 text-led-muted'
          }`}>
            {project.status}
          </span>
        </div>

        <p class="text-led-muted text-sm leading-relaxed mb-5">
          {project.description}
        </p>

        <div class="flex items-center justify-between">
          <div class="flex flex-wrap gap-2">
            {project.tags.map(tag => (
              <span class="font-mono text-xs text-led-muted border border-gray-800 px-2 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
          <div class="flex gap-3 text-sm font-mono">
            {project.repo && (
              <a href={project.repo} target="_blank" rel="noopener" class="text-led-muted hover:text-led-green transition-colors">
                repo ↗
              </a>
            )}
            {project.live && (
              <a href={project.live} target="_blank" rel="noopener" class="text-led-muted hover:text-led-green transition-colors">
                live ↗
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
