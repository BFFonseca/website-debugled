---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="mb-20">
    <p class="font-mono t-accent text-sm mb-3">hello, world —</p>
    <h1 class="font-display text-5xl font-bold t-text leading-tight mb-5">
      Welcome to <span class="t-accent">DebugLED</span>.<br />
      The most important component.
    </h1>
    <p class="t-muted text-lg max-w-xl leading-relaxed mb-8">
      Developer, maker, and occasional writer. This is where I document my projects,
      share what I learn, and keep an online presence that isn't LinkedIn.
    </p>
    <div class="flex gap-4">
      <a href="/projects" class="btn-primary">View Projects</a>
      <a href="/blog" class="btn-outline">Read Blog</a>
    </div>
  </section>

  <!-- About -->
  <section class="mb-20">
    <h2 class="section-title">About</h2>
    <p class="led-accent text-sm mb-6">// who I am</p>
    <div class="card max-w-2xl">
      <p class="t-muted leading-relaxed mb-4">
        My name's Bruno and I love to build things and watch cool stuff happen!
      </p>
      <p class="t-muted leading-relaxed">
        Currently working on: <span class="t-text">this website!</span>
        Yes, this website is my currently on-going project.
        Find out more on my first blog post: TBA
      </p>
    </div>
  </section>

  <!-- Skills / Stack -->
  <section>
    <h2 class="section-title">Toolbox</h2>
    <p class="led-accent text-sm mb-6">This is what I work with</p>
    <div class="flex flex-wrap gap-2">
      {['C', 'C++', 'Python', 'Git', 'VSCode', 'bash', 'OrcaSlicer', 'Autodesk Fusion', 'HomeAssistant', 'Claude', 'ChatGPT'].map(skill => (
        <span class="skill-tag font-mono text-xs px-3 py-1.5 rounded-full border t-muted b-border hover-accent transition-colors">
          {skill}
        </span>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .skill-tag:hover { border-color: var(--accent); }
</style>
