---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Astro content collections will replace this once you add real posts.
// For now this is a static placeholder list.
const posts = [
  {
    slug: 'hello-world',
    title: 'Hello World',
    date: '2026-01-01',
    description: 'The obligatory first post. Why I started this site and what to expect.',
    tags: ['meta'],
  },
];
---

<BaseLayout title="Blog" description="Thoughts, write-ups and notes.">
  <h1 class="section-title text-4xl mb-2">Blog</h1>
  <p class="led-accent text-sm mb-12">// thoughts & write-ups</p>

  {posts.length === 0 ? (
    <p class="text-led-muted font-mono">// no posts yet. coming soon.</p>
  ) : (
    <div class="flex flex-col gap-6">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="card group block">
          <div class="flex items-start justify-between gap-4 mb-2">
            <h2 class="font-display text-xl font-semibold text-led-light group-hover:text-led-green transition-colors">
              {post.title}
            </h2>
            <time class="font-mono text-xs text-led-muted shrink-0 mt-1">{post.date}</time>
          </div>
          <p class="text-led-muted text-sm leading-relaxed mb-4">{post.description}</p>
          <div class="flex gap-2">
            {post.tags.map(tag => (
              <span class="font-mono text-xs text-led-muted border border-gray-800 px-2 py-1 rounded">
                #{tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
