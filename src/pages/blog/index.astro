---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Blog" description="Thoughts, write-ups and notes.">
  <h1 class="section-title text-4xl mb-2">Blog</h1>
  <p class="led-accent text-sm mb-12">// thoughts & write-ups</p>

  {posts.length === 0 ? (
    <p class="text-led-muted font-mono">// no posts yet. coming soon.</p>
  ) : (
    <div class="flex flex-col gap-6">
      {posts.map(post => {
        const slug = post.id.replace(/\.md$/, '');
        return (
          <a href={`/blog/${slug}`} class="card group block">
            <div class="flex items-start justify-between gap-4 mb-2">
              <h2 class="font-display text-xl font-semibold text-led-light group-hover:text-led-green transition-colors">
                {post.data.title}
              </h2>
              <time class="font-mono text-xs text-led-muted shrink-0 mt-1">{post.data.date}</time>
            </div>
            <p class="text-led-muted text-sm leading-relaxed mb-4">{post.data.description}</p>
            <div class="flex gap-2">
              {post.data.tags.map(tag => (
                <span class="font-mono text-xs text-led-muted border border-gray-800 px-2 py-1 rounded">
                  #{tag}
                </span>
              ))}
            </div>
          </a>
        );
      })}
    </div>
  )}
</BaseLayout>
